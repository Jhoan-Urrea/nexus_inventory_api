#######################################
# GLOBAL - GENERAL
#######################################
SPRING_PROFILES_DEFAULT=dev
PORT=10000

#######################################
# GLOBAL - MAIL / PASSWORD RECOVERY
#######################################
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_PROTOCOL=smtp
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_STARTTLS_REQUIRED=false
APP_MAIL_FROM=
PASSWORD_RESET_EXPIRATION_MS=600000
PASSWORD_RESET_MAX_VERIFICATION_ATTEMPTS=5

#######################################
# GLOBAL - AUTH / TOKENS
#######################################
JWT_REFRESH_EXPIRATION=604800000

#######################################
# GLOBAL - CORS
#######################################
APP_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
APP_CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept,Origin,X-Requested-With,X-CSRF-TOKEN
APP_CORS_MAX_AGE=3600
APP_CORS_ALLOW_CREDENTIALS=true

#######################################
# GLOBAL - COOKIES / SESSION
#######################################
APP_AUTH_COOKIES_HTTP_ONLY=true
APP_AUTH_COOKIES_PATH=/
APP_AUTH_COOKIES_ACCESS_TOKEN_NAME=access_token
APP_AUTH_COOKIES_REFRESH_TOKEN_NAME=refresh_token
APP_AUTH_COOKIES_ACCESS_TOKEN_MAX_AGE_SECONDS=900
APP_AUTH_COOKIES_REFRESH_TOKEN_MAX_AGE_SECONDS=604800

#######################################
# GLOBAL - SECURITY
#######################################
APP_SECURITY_CSRF_ENABLED=true
APP_SECURITY_CSRF_COOKIE_NAME=XSRF-TOKEN
APP_SECURITY_CSRF_HEADER_NAME=X-CSRF-TOKEN
APP_SECURITY_CSRF_COOKIE_HTTP_ONLY=false
APP_SECURITY_CSRF_COOKIE_SECURE=false
APP_SECURITY_CSRF_COOKIE_SAME_SITE=Lax
APP_SECURITY_CSRF_COOKIE_PATH=/
APP_SECURITY_ACTUATOR_ADMIN_ONLY=true
APP_SECURITY_ACTUATOR_HEALTH_PUBLIC=true
APP_SECURITY_PERMIT_PUBLIC_LOCATIONS=false

#######################################
# DEVELOPMENT (DEV) - DATABASE
#######################################
DEV_DB_URL=
DEV_DB_USERNAME=
DEV_DB_PASSWORD=

#######################################
# DEVELOPMENT (DEV) - JWT / WEB
#######################################
DEV_JWT_SECRET=
DEV_JWT_EXPIRATION=3600000
DEV_APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://127.0.0.1:3000
DEV_APP_SECURITY_PERMIT_SWAGGER_DOCUMENTATION=true
DEV_OPENAPI_SERVER_URL=http://localhost:8080

#######################################
# TEST - DATABASE
#######################################
TEST_DB_URL=
TEST_DB_USERNAME=
TEST_DB_PASSWORD=

#######################################
# TEST - JWT
#######################################
TEST_JWT_SECRET=
TEST_JWT_EXPIRATION=3600000

#######################################
# PRODUCTION (PROD) - DATABASE
#######################################
PROD_DB_URL=
PROD_DB_USERNAME=
PROD_DB_PASSWORD=
PROD_DB_POOL_MAX_SIZE=10
PROD_DB_POOL_MIN_IDLE=2
PROD_DB_POOL_IDLE_TIMEOUT=60000
PROD_DB_POOL_MAX_LIFETIME=1800000
PROD_DB_POOL_CONNECTION_TIMEOUT=20000

#######################################
# PRODUCTION (PROD) - JWT / WEB / SECURITY
#######################################
PROD_JWT_SECRET=
PROD_JWT_EXPIRATION=3600000
PROD_APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://frontend.example.com
PROD_APP_AUTH_COOKIES_DOMAIN=
PROD_APP_AUTH_COOKIES_SECURE=true
PROD_APP_AUTH_COOKIES_SAME_SITE=None
PROD_APP_SECURITY_CSRF_COOKIE_SECURE=true
PROD_APP_SECURITY_CSRF_COOKIE_SAME_SITE=None
PROD_APP_SECURITY_CSRF_COOKIE_PATH=/
PROD_APP_SECURITY_TRUST_FORWARDED_HEADERS=true
PROD_APP_SECURITY_PERMIT_SWAGGER_DOCUMENTATION=false
PROD_OPENAPI_SERVER_URL=https://api.example.com

#######################################
# LEGACY VARIABLES (COMMENTED FOR MIGRATION REFERENCE)
#######################################
# spring.profiles.default=<migrated to SPRING_PROFILES_DEFAULT>
# DB_DEV_URL=<migrated to DEV_DB_URL>
# DB_DEV_USER=<migrated to DEV_DB_USERNAME>
# DB_DEV_PASSWORD=<migrated to DEV_DB_PASSWORD>
# DB_TEST_URL=<migrated to TEST_DB_URL>
# DB_TEST_USER=<migrated to TEST_DB_USERNAME>
# DB_TEST_PASSWORD=<migrated to TEST_DB_PASSWORD>
# DB_PROD_URL=<migrated to PROD_DB_URL>
# DB_PROD_USER=<migrated to PROD_DB_USERNAME>
# DB_PROD_PASSWORD=<migrated to PROD_DB_PASSWORD>
# DB_POOL_MAX_SIZE=<migrated to PROD_DB_POOL_MAX_SIZE>
# DB_POOL_MIN_IDLE=<migrated to PROD_DB_POOL_MIN_IDLE>
# DB_POOL_IDLE_TIMEOUT=<migrated to PROD_DB_POOL_IDLE_TIMEOUT>
# DB_POOL_MAX_LIFETIME=<migrated to PROD_DB_POOL_MAX_LIFETIME>
# DB_POOL_CONNECTION_TIMEOUT=<migrated to PROD_DB_POOL_CONNECTION_TIMEOUT>
# jwt_secret=<migrated to DEV_JWT_SECRET / PROD_JWT_SECRET>
# jwt_expiration=<migrated to DEV_JWT_EXPIRATION / PROD_JWT_EXPIRATION>
# JWT_DEV_SECRET=<migrated to DEV_JWT_SECRET>
# JWT_DEV_EXPIRATION=<migrated to DEV_JWT_EXPIRATION>
# JWT_TEST_SECRET=<migrated to TEST_JWT_SECRET>
# JWT_TEST_EXPIRATION=<migrated to TEST_JWT_EXPIRATION>
# JWT_PROD_SECRET=<migrated to PROD_JWT_SECRET>
# JWT_PROD_EXPIRATION=<migrated to PROD_JWT_EXPIRATION>
# APP_CORS_ALLOWED_ORIGIN_PATTERNS=<split into DEV_APP_CORS_ALLOWED_ORIGIN_PATTERNS and PROD_APP_CORS_ALLOWED_ORIGIN_PATTERNS>
# APP_AUTH_COOKIES_DOMAIN=<use PROD_APP_AUTH_COOKIES_DOMAIN in production>
# APP_AUTH_COOKIES_SECURE=<use PROD_APP_AUTH_COOKIES_SECURE in production>
# APP_AUTH_COOKIES_SAME_SITE=<use PROD_APP_AUTH_COOKIES_SAME_SITE in production>
# APP_SECURITY_TRUST_FORWARDED_HEADERS=<use PROD_APP_SECURITY_TRUST_FORWARDED_HEADERS in production>
# APP_SECURITY_PERMIT_SWAGGER_DOCUMENTATION=<use DEV_APP_SECURITY_PERMIT_SWAGGER_DOCUMENTATION or PROD_APP_SECURITY_PERMIT_SWAGGER_DOCUMENTATION>
# OPENAPI_SERVER_URL=<use DEV_OPENAPI_SERVER_URL or PROD_OPENAPI_SERVER_URL>
# nexus_inventory=<unused legacy secret with no current consumer>
