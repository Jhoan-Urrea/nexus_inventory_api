#######################################
# DESARROLLO / BASE DE DATOS
#######################################
DB_DEV_URL=
DB_DEV_USER=
DB_DEV_PASSWORD=

DB_TEST_URL=
DB_TEST_USER=
DB_TEST_PASSWORD=

DB_PROD_URL=
DB_PROD_USER=
DB_PROD_PASSWORD=

PORT=10000
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
DB_POOL_IDLE_TIMEOUT=60000
DB_POOL_MAX_LIFETIME=1800000
DB_POOL_CONNECTION_TIMEOUT=20000

#######################################
# JWT
#######################################
# Variables compartidas actuales del proyecto
jwt_secret=
jwt_expiration=3600000
JWT_REFRESH_EXPIRATION=604800000

# Overrides opcionales por perfil
JWT_DEV_SECRET=
JWT_DEV_EXPIRATION=3600000
JWT_PROD_SECRET=
JWT_PROD_EXPIRATION=3600000
JWT_TEST_SECRET=
JWT_TEST_EXPIRATION=3600000

#######################################
# CORS
#######################################
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:3000,http://127.0.0.1:3000
APP_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
APP_CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept,Origin,X-Requested-With,X-CSRF-TOKEN
APP_CORS_MAX_AGE=3600
APP_CORS_ALLOW_CREDENTIALS=true

#######################################
# COOKIES
#######################################
APP_AUTH_COOKIES_HTTP_ONLY=true
APP_AUTH_COOKIES_DOMAIN=
APP_AUTH_COOKIES_SECURE=false
APP_AUTH_COOKIES_SAME_SITE=Lax
APP_AUTH_COOKIES_PATH=/
APP_AUTH_COOKIES_ACCESS_TOKEN_NAME=access_token
APP_AUTH_COOKIES_REFRESH_TOKEN_NAME=refresh_token
APP_AUTH_COOKIES_ACCESS_TOKEN_MAX_AGE_SECONDS=900
APP_AUTH_COOKIES_REFRESH_TOKEN_MAX_AGE_SECONDS=604800

#######################################
# CSRF
#######################################
APP_SECURITY_CSRF_ENABLED=true
APP_SECURITY_CSRF_COOKIE_NAME=XSRF-TOKEN
APP_SECURITY_CSRF_HEADER_NAME=X-CSRF-TOKEN
APP_SECURITY_CSRF_COOKIE_HTTP_ONLY=false
APP_SECURITY_TRUST_FORWARDED_HEADERS=false
APP_SECURITY_PERMIT_SWAGGER_DOCUMENTATION=false
APP_SECURITY_ACTUATOR_ADMIN_ONLY=true
APP_SECURITY_ACTUATOR_HEALTH_PUBLIC=true
APP_SECURITY_PERMIT_PUBLIC_LOCATIONS=false

#######################################
# CORREO / RECUPERACION DE CONTRASENA
#######################################
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_PROTOCOL=smtp
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_STARTTLS_REQUIRED=false
APP_MAIL_FROM=

PASSWORD_RESET_EXPIRATION_MS=600000
PASSWORD_RESET_MAX_VERIFICATION_ATTEMPTS=5

#######################################
# OPENAPI
#######################################
OPENAPI_SERVER_URL=http://localhost:8080
